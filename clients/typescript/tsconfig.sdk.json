{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.sdk.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* SDK specific settings */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    
    /* Balanced strictness for SDK */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noUncheckedSideEffectImports": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    
    /* Disabled for compatibility with existing code */
    "exactOptionalPropertyTypes": false,
    "allowUnreachableCode": true,
    "allowUnusedLabels": true,
    
    /* Additional SDK-specific options */
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    
    /* Import-related settings */
    "resolveJsonModule": false,
    "composite": false
  },
  "include": ["src/sdk", "src/@types"],
  "exclude": ["node_modules", "dist"]
}