# Realtime TypeScript Client Configuration

# WebSocket URL of the Realtime API backend
# Leave empty to auto-detect from current hostname (ws://<host>:8080/ws)
VITE_WEBSOCKET_URL=

# Enable debug logging in the browser console
VITE_DEBUG_MODE=false

# WebSocket reconnection settings
VITE_MAX_RECONNECT_ATTEMPTS=5
VITE_RECONNECT_INTERVAL=3000
