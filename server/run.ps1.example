# =============================================================================
# Realtime API - PowerShell 启动脚本模板
# =============================================================================
# 使用方法：
#   1. 复制此文件：Copy-Item run.ps1.example run.ps1
#   2. 填入真实的配置值
#   3. 运行：.\run.ps1
# =============================================================================

# -----------------------------------------------------------------------------
# 基础配置
# -----------------------------------------------------------------------------
$env:RUST_LOG = "info"
$env:RUST_BACKTRACE = "1"
$env:BIND_ADDR = "0.0.0.0:8080"
$env:MAX_CONCURRENT_SESSIONS = "10"
$env:ACTIX_WORKER_THREADS = "4"

# -----------------------------------------------------------------------------
# 搜索后端配置 (可选)
# -----------------------------------------------------------------------------
$env:SEARCH_BACKEND = "tavily"
$env:TAVILY_API_TOKEN = $env:TAVILY_API_TOKEN ?? "your_tavily_api_token"

# -----------------------------------------------------------------------------
# TTS 配置 - VolcEngine (火山引擎)
# 从火山引擎控制台获取凭证
# -----------------------------------------------------------------------------
$env:VOLC_APP_ID = $env:VOLC_APP_ID ?? "your_volc_app_id"
$env:VOLC_ACCESS_TOKEN = $env:VOLC_ACCESS_TOKEN ?? "your_volc_access_token"
$env:VOLC_RESOURCE_ID = "volc.service_type.10029"
$env:VOLC_SPEAKER = "zh_female_wanwanxiaohe_moon_bigtts"

# -----------------------------------------------------------------------------
# TTS 配置 - MiniMax (可选)
# 从 MiniMax 控制台获取 API Key
# -----------------------------------------------------------------------------
# $env:MINIMAX_TTS_API_KEY = $env:MINIMAX_TTS_API_KEY ?? "your_minimax_api_key"
# $env:MINIMAX_TTS_ACTUAL_VOICE_ID = "wanwanxiaohe_moon2"

# -----------------------------------------------------------------------------
# LLM 配置
# 替换为你的 LLM 服务地址
# -----------------------------------------------------------------------------
$env:LLM_BASE_URL = $env:LLM_BASE_URL ?? "http://localhost:8000/v1"

# -----------------------------------------------------------------------------
# ASR 配置
# -----------------------------------------------------------------------------
$env:WHISPERLIVE_PATH = $env:WHISPERLIVE_PATH ?? "ws://localhost:9090"
$env:WEBSOCKET_ASR_ENDPOINTS = $env:WEBSOCKET_ASR_ENDPOINTS ?? "ws://localhost:43007"
$env:DENOISER_ENABLED = "true"

# -----------------------------------------------------------------------------
# 意图识别服务配置 (可选)
# -----------------------------------------------------------------------------
$env:INTENT_API_URL = $env:INTENT_API_URL ?? "http://localhost/intent"

# -----------------------------------------------------------------------------
# 搜索服务配置 (可选)
# -----------------------------------------------------------------------------
$env:SEARXNG_BASE_URL = $env:SEARXNG_BASE_URL ?? "http://localhost:8787"

# -----------------------------------------------------------------------------
# 视觉 LLM 配置 (可选)
# -----------------------------------------------------------------------------
# $env:VISUAL_LLM_STREAM_URL = $env:VISUAL_LLM_STREAM_URL ?? "http://localhost:19444/v2/chat/completions"

# -----------------------------------------------------------------------------
# Langfuse 监控配置 (可选)
# -----------------------------------------------------------------------------
# $env:LANGFUSE_SECRET_KEY = $env:LANGFUSE_SECRET_KEY ?? "your_langfuse_secret_key"
# $env:LANGFUSE_PUBLIC_KEY = $env:LANGFUSE_PUBLIC_KEY ?? "your_langfuse_public_key"
# $env:LANGFUSE_BASE_URL = $env:LANGFUSE_BASE_URL ?? "http://localhost:13000"

# -----------------------------------------------------------------------------
# 启动服务
# -----------------------------------------------------------------------------
cargo run --features binary-audio --bin realtime
