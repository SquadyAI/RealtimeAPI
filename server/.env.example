# =============================================================================
# Realtime API - Environment Variables Template
# Realtime API - 环境变量配置模板
# =============================================================================
# Copy this file to .env and fill in your values
# 复制此文件为 .env 并填入真实值
#   cp .env.example .env
#   ./realtime onboard   # or use the interactive wizard / 或使用交互式向导
# =============================================================================

# UI language for CLI scripts (en / zh). Auto-detected on first run.
# CLI 脚本界面语言（en / zh）。首次运行时自动检测。
# UI_LANG=en

# -----------------------------------------------------------------------------
# Service Configuration / 服务配置
# -----------------------------------------------------------------------------
BIND_ADDR=0.0.0.0:8080
MAX_CONCURRENT_SESSIONS=100
RUST_LOG=info
RUST_BACKTRACE=1

# Actix worker threads (default: number of CPU cores)
# Actix 工作线程数（默认：CPU 核心数）
# ACTIX_WORKER_THREADS=4

# Remote config cache TTL in seconds (0 = disable cache)
# 远程配置缓存 TTL 秒数（0 = 禁用缓存）
# REMOTE_CONFIG_CACHE_TTL_SECS=10

# -----------------------------------------------------------------------------
# LLM Configuration (REQUIRED) / LLM 配置（必需）
# -----------------------------------------------------------------------------
# OpenAI-compatible API endpoint / OpenAI 兼容接口地址
LLM_BASE_URL=https://api.openai.com/v1
# API Key
LLM_API_KEY=sk-your-api-key-here
# Model name / 模型名称
LLM_MODEL=gpt-3.5-turbo
# Request timeout in seconds / 超时时间（秒）
LLM_TIMEOUT_SECS=30
# Skip SSL certificate verification / 跳过 SSL 证书验证
# LLM_SKIP_CERT_VERIFICATION=false
# Default system prompt (used when client does not provide one)
# 默认系统提示词（客户端未提供时使用）
# DEFAULT_SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses concise and conversational. Reply in the same language as the user.

# -----------------------------------------------------------------------------
# ASR Configuration / ASR 配置（语音识别）
# -----------------------------------------------------------------------------
# WhisperLive ASR service URL / WhisperLive ASR 服务地址
# WHISPERLIVE_PATH=ws://localhost:9090

# Language-based ASR routing (JSON) / 按语言路由 ASR（JSON 格式）
# WHISPERLIVE_ROUTING={"zh": {"url":"ws://localhost:9091","hotwords":false}, "*": {"url":"ws://localhost:9092","hotwords":false}}

# Additional ASR WebSocket endpoints / 额外的 ASR WebSocket 端点
# WEBSOCKET_ASR_ENDPOINTS=ws://localhost:43007

# ONNX Runtime (for local builds) / ONNX Runtime（本地编译时需要）
# ORT_LIB_LOCATION=/usr/local/lib
# ORT_STRATEGY=system

# -----------------------------------------------------------------------------
# VAD Configuration / VAD 配置（语音活动检测）
# -----------------------------------------------------------------------------
VAD_THRESHOLD=0.6
VAD_MIN_SILENCE_MS=500
VAD_MIN_SPEECH_MS=120
VAD_GPU_ENABLED=false

# SmartTurn semantic-level VAD / SmartTurn 语义级 VAD
# VAD_SEMANTIC_THRESHOLD=0.5
# VAD_DELTA_PROCESS_SILENCE_CHUNK=1000

# -----------------------------------------------------------------------------
# TTS Configuration / TTS 配置（语音合成）
# -----------------------------------------------------------------------------
ENABLE_TTS=true

# Engine: edge (free) | azure | minimax | volc | baidu
# 引擎: edge（免费）| azure | minimax | volc | baidu
TTS_ENGINE=edge
TTS_MAX_CONCURRENT=5
TTS_BUFFER_SIZE=8192

# Idle timeout before returning final audio chunk (seconds)
# 空闲超时，返回最终音频块的时间（秒）
TTS_IDLE_RETURN_SECS=120

# Max TTS sessions / 最大 TTS 会话数
TTS_MAX_SESSIONS=1000

# --- MiniMax TTS ---
# MINIMAX_API_KEY=your_minimax_api_key_here

# --- Azure Speech ---
# AZURE_SPEECH_KEY=your_azure_speech_key
# AZURE_SPEECH_REGION=eastus

# --- VolcEngine TTS / 火山引擎 TTS ---
# VOLC_APP_ID=your_volc_app_id
# VOLC_ACCESS_TOKEN=your_volc_access_token
# VOLC_RESOURCE_ID=volc.service_type.10029
# VOLC_SPEAKER=zh_female_wanwanxiaohe_moon_bigtts

# --- Baidu TTS / 百度 TTS ---
# BAIDU_TTS_API_KEY=your_baidu_api_key
# BAIDU_TTS_SECRET_KEY=your_baidu_secret_key
# BAIDU_TTS_PER=4197

# Voice library config file / 音色库配置文件
# VOICE_LIBRARY_CONFIG_PATH=/path/to/voice_library.json

# -----------------------------------------------------------------------------
# Audio Processing / 音频处理
# -----------------------------------------------------------------------------
SAMPLE_RATE=16000
CHUNK_SIZE=1024
BUFFER_SIZE=8192

# Audio denoiser / 音频降噪
# DENOISER_ENABLED=true

# Block audio input during TTS playback (ms) / TTS 播放时阻塞音频输入（毫秒）
# AUDIO_BLOCKING_DURATION_MS=1500

# -----------------------------------------------------------------------------
# Search / 搜索配置（可选）
# -----------------------------------------------------------------------------
# SEARXNG_BASE_URL=http://localhost:8787
# SEARXNG_TIMEOUT_MS=5000
# SEARXNG_MAX_RESULTS=20

# -----------------------------------------------------------------------------
# Storage / 存储配置（可选）
# -----------------------------------------------------------------------------
# PostgreSQL connection URL / PostgreSQL 连接地址
# DATABASE_URL=postgresql://user:password@localhost:5432/realtime_db

# -----------------------------------------------------------------------------
# Monitoring / 监控配置（可选）
# -----------------------------------------------------------------------------
# Langfuse tracing / Langfuse 追踪
# LANGFUSE_SECRET_KEY=your_langfuse_secret_key
# LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# tokio-console debugging / tokio-console 调试
# TOKIO_CONSOLE=true
# TOKIO_CONSOLE_PORT=16992

# -----------------------------------------------------------------------------
# Geolocation / 地理位置（可选）
# -----------------------------------------------------------------------------
# GEOIP_MMDB_PATH=/app/data/GeoIP2-City.mmdb
# GEONAMES_CITIES_FILE=/app/data/cities500.txt

# -----------------------------------------------------------------------------
# Intent Recognition / 意图识别（可选）
# -----------------------------------------------------------------------------
# INTENT_API_URL=http://localhost/intent

# -----------------------------------------------------------------------------
# Simultaneous Interpretation / 同声传译（可选）
# -----------------------------------------------------------------------------
# ENABLE_SIMUL_INTERPRET=true

# -----------------------------------------------------------------------------
# Vision LLM / 视觉 LLM（可选）
# -----------------------------------------------------------------------------
# VISUAL_LLM_STREAM_URL=http://localhost:38000/v1/chat/completions

# -----------------------------------------------------------------------------
# GPU Configuration / GPU 配置（仅 GPU 版本）
# -----------------------------------------------------------------------------
# CUDA_VISIBLE_DEVICES=0
# VAD_GPU_ENABLED=true
